# QuantOnion — Environment Variable Template
# Copy this file to .env and fill in your values.
# None of these keys are required for basic functionality.
# The app works out of the box using Yahoo Finance (free, no key needed).

# ── ConnectOnion Agent ────────────────────────────────────────────────────────
# Enables full AI-powered research analysis in the Agent tab.
# ConnectOnion authenticates via CLI — no API key required here.
# Setup: pip install connectonion && co auth

# ── Optional Data Source Keys ─────────────────────────────────────────────────
# Alpha Vantage free tier: 25 requests/day
# https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY = "TCNI0VN0JFW35UX0"


# Twelve Data free tier: 800 requests/day
# https://twelvedata.com/account
TWELVE_DATA_API_KEY = "b1012914d8494bd4a32455bba2dd242b"


# ── Sentiment & News (optional) ───────────────────────────────────────────────
# Finnhub free tier: 60 API calls/min — used by get_news_sentiment() for richer data
# https://finnhub.io/register
FINNHUB_API_KEY = "your_finnhub_key_here"

# StockTwits, Reddit, alternative.me Fear & Greed, and VIX (via yfinance)
# require NO API key — they are public sources used automatically.


# ── Notes ─────────────────────────────────────────────────────────────────────
# For Streamlit Cloud deployment, add these as secrets in the Streamlit dashboard
# (not as .env file — .env is for local development only).
#
# For Render.com deployment, add as environment variables in the service settings.
#
# Never commit .env to version control. It is already in .gitignore.
